rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidConversation(data) {
      return data.keys().hasAll(['id', 'title', 'userId', 'createdAt', 'updatedAt']) &&
             data.id is string &&
             data.title is string && data.title.size() <= 100 &&
             data.userId is string &&
             data.createdAt is number &&
             data.updatedAt is number;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['id', 'role', 'content', 'timestamp']) &&
             data.id is string &&
             data.role in ['user', 'assistant'] &&
             data.content is string && data.content.size() <= 10000 &&
             data.timestamp is number;
    }

    match /conversations/{conversationId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId) && isValidConversation(request.resource.data);
      allow update: if isOwner(resource.data.userId) && 
                      isValidConversation(request.resource.data) &&
                      request.resource.data.userId == resource.data.userId &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isOwner(resource.data.userId);

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          isOwner(get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId)
        );
        allow create: if isOwner(get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId) && 
                         isValidMessage(request.resource.data);
        allow update: if isOwner(get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId) &&
                         isValidMessage(request.resource.data);
        allow delete: if isOwner(get(/databases/$(database)/documents/conversations/$(conversationId)).data.userId);
      }
    }

    match /projects/{projectId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }

    match /memory/{memoryId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(resource.data.userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
